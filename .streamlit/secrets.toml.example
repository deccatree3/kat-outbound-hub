# Streamlit Cloud secrets (또는 로컬 개발 시 .streamlit/secrets.toml)
# 이 파일은 .gitignore 에 등록되어 있으니 실제 값은 secrets.toml 에 입력.

# Supabase 신규 프로젝트 (kat-outbound-hub 전용)
DATABASE_URL = "postgresql://postgres.XXXX:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres"

# Qoo10 QAPI 자격증명 (운영용 - 사이드바 UI에서 DB에 저장하면 이 값들 없어도 됨)
QOO10_API_KEY  = "GiosisCertificationKey"
QOO10_USER_ID  = "adminkatchers"
QOO10_PASSWORD = "..."
